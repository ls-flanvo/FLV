# ============================================
# FLANVO — Environment Variables Template
# Copia questo file in .env e compila i valori
# ============================================

# DATABASE (Supabase)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# JWT (min 32 caratteri, cambia in produzione)
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Resend (email)
RESEND_API_KEY=re_...

# App URL
NEXT_PUBLIC_APP_URL=https://flanvo.vercel.app
